"""
Disk image build configuration.
"""

import os

from SCons.Action import Action
from SCons.Environment import Environment
from SCons.Script import Flatten

from scripts.scons.utility import GlobRecursive
from scripts.scons.disk import (
    VolumeLabel,
    CreateBootableIso,
    FormatPartitionImage,
    GenerateGrubConfig,
    GetGrubModules,
    GetPartitionTypeIdentifier,
)

Import('Kernel')
Import('UserLibraries')
Import('UserApplications')
Import('TargetEnvironment')

TargetEnvironment: Environment
Env: Environment = TargetEnvironment


def BuildDisk(ImagePath, KernelExecutablePath, Libraries, Applications, ExtraFiles, EnvironmentObject):
    import sh
    import shutil

    ImageSize = EnvironmentObject['ImageSize']
    Filesystem = EnvironmentObject['ImageFs']
    OutputFormat = EnvironmentObject.get('ImageFormat', 'img')
    Architecture = EnvironmentObject.get('BuildArch', 'i686')
    BuildConfig = EnvironmentObject.get('BuildConfig', 'release')

    Volume = VolumeLabel
    PartStartMb = 1
    PartitionTypeIdentifier = GetPartitionTypeIdentifier(Filesystem)
    GrubCoreName = 'grub.core'
    BootHeadName = 'boot_head.img'
    GrubPath = '/usr/lib/grub/i386-pc'

    TotalMb = max(1, (ImageSize + (1024 * 1024 - 1)) // (1024 * 1024))
    PartMb = TotalMb - PartStartMb
    if PartMb <= 0:
        raise RuntimeError('Invalid partition sizing: partSizeMB must be > 0')
    PartStartSector = PartStartMb * 2048

    BuildTag = f'{Architecture}_{BuildConfig}'
    Stage = EnvironmentObject.get('ImageStagingDirectory', os.path.join('build', BuildTag, 'img'))

    os.makedirs(Stage, exist_ok=True)
    for Entry in os.listdir(Stage):
        if Entry == 'usr':
            Usr = os.path.join(Stage, 'usr')
            if os.path.isdir(Usr):
                for Sub in os.listdir(Usr):
                    if Sub in ('include', 'lib'):
                        continue
                    SubPath = os.path.join(Usr, Sub)
                    if os.path.isdir(SubPath):
                        shutil.rmtree(SubPath)
                    else:
                        os.remove(SubPath)
            continue
        if Entry == 'lib':
            continue
        EntryPath = os.path.join(Stage, Entry)
        if os.path.isdir(EntryPath):
            shutil.rmtree(EntryPath)
        else:
            os.remove(EntryPath)

    print(f"   STAGE -> {Stage}")

    import subprocess
    Compiler = EnvironmentObject.subst('$CC')
    try:
        RuntimeSysroot = subprocess.check_output([Compiler, '-print-sysroot'], text=True).strip()
    except Exception:
        RuntimeSysroot = ''

    if not RuntimeSysroot or not os.path.isdir(RuntimeSysroot):
        print(f"   STAGE WARNING: Missing toolchain sysroot from '{Compiler} -print-sysroot' (got: {RuntimeSysroot})")
    else:
        print(f"   STAGE SYSROOT -> {RuntimeSysroot}")
        for Entry in os.listdir(RuntimeSysroot):
            SrcPath = os.path.join(RuntimeSysroot, Entry)
            DstPath = os.path.join(Stage, Entry)

            if os.path.lexists(DstPath):
                if os.path.isdir(DstPath) and not os.path.islink(DstPath):
                    shutil.rmtree(DstPath)
                else:
                    os.remove(DstPath)

            if os.path.isdir(SrcPath) and not os.path.islink(SrcPath):
                shutil.copytree(SrcPath, DstPath, symlinks=True)
            else:
                shutil.copy2(SrcPath, DstPath, follow_symlinks=False)

    BootDir = os.path.join(Stage, 'boot')
    os.makedirs(BootDir, exist_ok=True)
    print(f"   STAGE {os.path.basename(KernelExecutablePath)} -> /boot")
    shutil.copy2(KernelExecutablePath, BootDir)

    GenerateGrubConfig(
        os.path.join(BootDir, 'grub'),
        OutputFormat,
        Config=EnvironmentObject['BuildConfig'],
        KernelName=EnvironmentObject['KernelOutputName'],
        VolumeLabelName=Volume,
    )

    if Libraries:
        LibDir = os.path.join(Stage, 'usr', 'lib')
        os.makedirs(LibDir, exist_ok=True)
        for Lib in Libraries:
            print(f"   STAGE {os.path.basename(Lib)} -> /usr/lib")
            shutil.copy2(Lib, LibDir)

    if Applications:
        BinDir = os.path.join(Stage, 'usr', 'bin')
        os.makedirs(BinDir, exist_ok=True)
        for App in Applications:
            print(f"   STAGE {os.path.basename(App)} -> /usr/bin")
            shutil.copy2(App, BinDir)

    SourceRoot = EnvironmentObject['BASEDIR']
    for Node in ExtraFiles:
        Src = Node.srcnode().path
        Rel = os.path.relpath(Src, SourceRoot)
        Dst = os.path.join(Stage, Rel)
        if os.path.isdir(Src):
            os.makedirs(Dst, exist_ok=True)
        else:
            print(f"   STAGE {Rel}")
            os.makedirs(os.path.dirname(Dst), exist_ok=True)
            shutil.copy2(Src, Dst)

    if OutputFormat == 'iso':
        CreateBootableIso(Stage, ImagePath, Volume)

    else:
        ImgDir = os.path.dirname(ImagePath) or '.'
        TmpPart = os.path.join(ImgDir, 'part.tmp')
        GrubCore = os.path.join(ImgDir, GrubCoreName)
        BootHead = os.path.join(ImgDir, BootHeadName)

        print("   GRUB-MKIMAGE")
        sh.Command('grub-mkimage')(
            '-O', 'i386-pc',
            '-o', GrubCore,
            '-p', '(hd0,msdos1)/boot/grub',
            *GetGrubModules(Filesystem),
        )

        with open(os.path.join(GrubPath, 'boot.img'), 'rb') as BootImg, \
             open(GrubCore, 'rb') as CoreImg, \
             open(BootHead, 'wb') as OutImg:
            OutImg.write(BootImg.read())
            OutImg.write(CoreImg.read())

        try:
            print(f"   CREATE PARTITION FILE {Filesystem}")
            sh.truncate('-s', f'{PartMb}M', TmpPart)
            FormatPartitionImage(TmpPart, Filesystem, Volume)

            print("   CREATE MBR")
            sh.truncate('-s', f'{TotalMb}M', ImagePath)
            GuestfishMbr = '\n'.join([
                'run',
                'part-init /dev/sda mbr',
                f'part-add /dev/sda p {PartStartSector} -1',
                f'part-set-mbr-id /dev/sda 1 {PartitionTypeIdentifier}',
                'quit',
                '',
            ])
            sh.Command('guestfish')('-a', ImagePath, _in=GuestfishMbr)

            print("   SPLICE PARTITION")
            sh.dd(
                f'if={TmpPart}',
                f'of={ImagePath}',
                'bs=512',
                f'seek={PartStartSector}',
                'conv=notrunc',
                'status=none',
            )

            print("   WRITE BOOTLOADER")
            sh.dd(
                f'if={BootHead}',
                f'of={ImagePath}',
                'bs=446',
                'count=1',
                'conv=notrunc',
                'status=none',
            )
            sh.dd(
                f'if={BootHead}',
                f'of={ImagePath}',
                'bs=512',
                'skip=1',
                'seek=1',
                'conv=notrunc',
                'status=none',
            )

            with open(ImagePath, 'r+b') as DiskFile:
                DiskFile.seek(92)
                DiskFile.write(b'\x01\x00\x00\x00')

            print(f"   INJECT FILES {Stage}")
            GuestfishCopy = '\n'.join([
                'run',
                'mount /dev/sda1 /',
                f'copy-in {Stage}/. /',
                'quit',
                '',
            ])
            sh.Command('guestfish')('-a', ImagePath, _in=GuestfishCopy)

        finally:
            for Tmp in (TmpPart, BootHead, GrubCore):
                if os.path.exists(Tmp):
                    os.remove(Tmp)


def BuildImageAction(*_Args, **KeywordArguments):
    Target = KeywordArguments['target']
    Source = KeywordArguments['source']
    EnvObj = KeywordArguments['env']
    KernelName = EnvObj['KernelOutputName']
    KernelExecutablePath = None

    for Src in Source:
        PathStr = str(Src)
        Base = os.path.basename(PathStr)
        if Base == KernelName or Base.startswith(KernelName + '.'):
            KernelExecutablePath = PathStr
            break

    if KernelExecutablePath is None:
        raise RuntimeError("Kernel executable not found in build inputs")

    LibraryNodes = Flatten(UserLibraries)
    LibraryPaths = []
    LibrarySet = set()
    for Library in LibraryNodes:
        AbsolutePath = Library.get_abspath() if hasattr(Library, 'get_abspath') else str(Library)
        LibraryPaths.append(AbsolutePath)
        LibrarySet.add(str(Library))

    ApplicationNodes = Flatten(UserApplications)
    ApplicationPaths = []
    ApplicationSet = set()
    for Application in ApplicationNodes:
        AbsolutePath = Application.get_abspath() if hasattr(Application, 'get_abspath') else str(Application)
        ApplicationPaths.append(AbsolutePath)
        ApplicationSet.add(str(Application))

    ExtraFiles = [
        Src for Src in Source
        if str(Src) != KernelExecutablePath and str(Src) not in LibrarySet and str(Src) not in ApplicationSet
    ]

    BuildDisk(str(Target[0]), KernelExecutablePath, LibraryPaths, ApplicationPaths, ExtraFiles, EnvObj)


Root = Env.Dir('root')
RootFiles = GlobRecursive(Env, '*', Root)

Inputs = [Kernel] + UserLibraries + UserApplications + RootFiles

OutputFormat = Env['ImageFormat']
Out = f'{Env["ImageName"]}-{Env["ProjVersion"]}_{Env["BuildConfig"]}_{Env["BuildArch"]}.{OutputFormat}'

Image = Env.Command(
    Out,
    Inputs,
    action=Action(BuildImageAction, '   CREATING DISK'),
    BASEDIR=Root.srcnode().path,
)

Export('Image')