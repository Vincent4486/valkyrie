from SCons.Script import Command, Dir, File, Return
import os
import subprocess

Import('Sources')
Import('CoreSources')

# Generate font_gen.c from the bitmap font script.
FontScript = File('genfont.sh')
FontTarget = Command(target='font_gen.c', source=FontScript,
                     action=f'bash {FontScript.srcnode().abspath} $TARGET')[0]

# =============================================================================
# Generated Source Files
# =============================================================================

GenfontPath = os.path.join('genfont.sh')
if os.path.exists(GenfontPath):
    GenfontC = os.path.join('font_gen.c')
    
    if not os.path.exists(GenfontC):
        subprocess.run(['bash', GenfontPath, GenfontC], check=True)

Sources += [
    FontTarget,
    File('serial.c'),
    File('vbe.c'),
    File('vga_text.c'),
    File('vga.c'),
    File('print.c'),
]

CoreSources += [
    FontTarget,
    File('serial.c'),
    File('vbe.c'),
    File('vga_text.c'),
    File('vga.c'),
    File('print.c'),
]
