"""
Bootloader build configuration.
"""

import os
import subprocess
import sys

from SCons.Environment import Environment
from SCons.Script import Dir, Export, SConscript

from scripts.scons.arch import GetArchConfig
from scripts.scons.bootloader import (
    ConfigureBootloaderEnvironment,
    GetBootloaderBuildConfig,
)


Import('TargetEnvironment')
TargetEnvironment: Environment

# =============================================================================
# Environment Setup
# =============================================================================

MainEnvironment = TargetEnvironment.Clone()

SourcePath = Dir('#bootloader').abspath
Architecture = TargetEnvironment['BuildArch']
BootType = TargetEnvironment['BootType']
ArchitecturePath = os.path.join(SourcePath, BootType, Architecture)

ArchitectureConfig = GetArchConfig(Architecture)
BootloaderBuildConfig = GetBootloaderBuildConfig(BootType, Architecture)

ConfigureBootloaderEnvironment(
    MainEnvironment,
    SourcePath,
    ArchitecturePath,
    ArchitectureConfig,
    BootloaderBuildConfig,
)

# =============================================================================
# Generated Source Files
# =============================================================================

if BootType == 'bios':
    VideoPath = os.path.join(SourcePath, 'bios', 'video')

    MkfontPath = os.path.join(VideoPath, 'mkfont.py')
    FontGenC = os.path.join(VideoPath, 'font_gen.c')
    if os.path.exists(MkfontPath) and not os.path.exists(FontGenC):
        subprocess.run([sys.executable, MkfontPath, FontGenC], check=True)

    MklogoPath = os.path.join(VideoPath, 'mklogo.py')
    LogoGenH = os.path.join(VideoPath, 'logo_gen.h')
    if os.path.exists(MklogoPath) and not os.path.exists(LogoGenH):
        subprocess.run([sys.executable, MklogoPath, LogoGenH], check=True)

# =============================================================================
# Source Files
# =============================================================================

Sources = []
SConscript('common/SConscript', exports='Sources')

BootloaderComponents = {
    'BootType': BootType,
    'Architecture': Architecture,
}

if BootType == 'bios':
    BootBin = MainEnvironment.File('boot.bin')
    CoreBin = MainEnvironment.File('core.bin')
    BootloaderComponents['Stage1'] = BootBin
    BootloaderComponents['Stage2'] = CoreBin
    SConscript(
        'bios/SConscript',
        exports=[
            'TargetEnvironment',
            'SourcePath',
            'ArchitecturePath',
            'ArchitectureConfig',
            'BootloaderBuildConfig',
            'Sources',
            'Architecture',
            'BootBin',
            'CoreBin',
        ],
    )
elif BootType == 'efi':
    EfiBin = MainEnvironment.File('boot.efi')
    BootloaderComponents['EfiBinary'] = EfiBin
    SConscript(
        'efi/SConscript',
        exports=[
            'TargetEnvironment',
            'SourcePath',
            'ArchitecturePath',
            'ArchitectureConfig',
            'BootloaderBuildConfig',
            'Sources',
            'Architecture',
            'EfiBin',
        ],
    )
else:
    raise RuntimeError(f'Unsupported boot type: {BootType}')

TargetEnvironment['BootloaderComponents'] = BootloaderComponents

MainEnvironment.Append(OBJPREFIX='main_')
Objects = MainEnvironment.Object(Sources)


# =============================================================================
# Build Target
# =============================================================================

Bootloader = MainEnvironment.Library(BootloaderBuildConfig['OutputName'], Objects)

Export('Bootloader')
