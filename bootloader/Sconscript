"""
Bootloader builder
"""

import os
import re

from SCons.Action import Action
from SCons.Environment import Environment
from SCons.Script import Flatten

Import('TARGET_ENVIRONMENT')
TARGET_ENVIRONMENT: Environment

# =============================================================================
# Environment Setup
# =============================================================================

env = TARGET_ENVIRONMENT.Clone()
src_dir = Dir('#bootloader').abspath
arch = TARGET_ENVIRONMENT['arch']
boot = TARGET_ENVIRONMENT['boot']

arch_dir = os.path.join(src_dir, f'{arch}-{boot}')
linker_script = os.path.join(arch_dir, 'linker.ld')