"""
Bootloader builder
"""

import os
import re

from SCons.Action import Action
from SCons.Environment import Environment
from SCons.Script import Flatten

Import('TargetEnvironment')
TargetEnvironment: Environment

# =============================================================================
# Environment Setup
# =============================================================================

env = TargetEnvironment.Clone()
srcpath = Dir('#bootloader').abspath
arch = TargetEnvironment['build.arch']
boot = TargetEnvironment['boot.type']

archpath = os.path.join(srcpath, f'{arch}-{boot}')
linkerscript = os.path.join(archpath, 'linker.ld')