"""
sh - Shell application build configuration.
"""

from SCons.Script import Dir, Export

from scripts.scons.utility import GlobSources

Import('UsermodeEnv')

Env = UsermodeEnv.Clone()

Srcpath = Dir('#usr/sh').abspath

Env.Append(
    CPATH=[Srcpath],
    CPPPATH=[Srcpath],
)

Sources = GlobSources(Srcpath)
Objects = Env.Object(Sources)

ShExecutable = Env.Program('sh', Objects)

ShModule = ShExecutable
Export('ShModule')
